<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dental Shop Admin Login</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            background-color: #f5f5f5;
            min-height: 100vh;
        }

        /* Navigation Styles */
        .nav {
            background-color: white;
            padding: 1rem 2rem;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
        }

        .nav-logo {
            display: inline-block;
        }

        .nav-logo span:first-child {
            background: #444;
            color: #ffd233;
            padding: 5px 10px;
            font-weight: bold;
            font-size: 24px;
        }

        .nav-logo span:last-child {
            background: #ffd233;
            color: #444;
            padding: 5px 10px;
            font-weight: bold;
            font-size: 24px;
        }

        /* Login Container Styles */
        .page-container {
            padding-top: 100px;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-container {
            background: white;
            padding: 2rem;
            border-radius: 8px;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 400px;
        }

        .login-header {
            text-align: center;
            margin-bottom: 2rem;
            color: #444;
        }

        .login-header h2 {
            font-size: 24px;
            font-weight: 600;
        }

        .input-group {
            margin-bottom: 1.5rem;
        }

        .input-group label {
            display: block;
            margin-bottom: 0.5rem;
            color: #444;
            font-weight: 500;
        }

        .input-group input {
            width: 100%;
            padding: 0.75rem;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 1rem;
        }

        .input-group input:focus {
            outline: none;
            border-color: #ffd233;
        }

        .login-btn {
            width: 100%;
            padding: 0.75rem;
            background: #444;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 1rem;
            cursor: pointer;
            transition: background 0.3s ease;
        }

        .login-btn:hover {
            background: #333;
        }

        .error-message {
            color: #ff4444;
            font-size: 0.875rem;
            margin-top: 0.5rem;
            display: none;
        }

        /* Additional link styles */
        .forgot-password {
            text-align: right;
            margin-bottom: 1rem;
        }

        .forgot-password a {
            color: #444;
            text-decoration: none;
            font-size: 0.875rem;
        }

        .forgot-password a:hover {
            color: #ffd233;
        }
    </style>
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="nav">
        <div class="nav-logo">
            <span>DENT</span><span>CART</span>
        </div>
    </nav>

    <!-- Login Page Container -->
    <div class="page-container">
        <div class="login-container">
            <div class="login-header">
                <h2>Admin Login</h2>
            </div>
            <% if (message) { %>
                <p style="color: red;
                text-align: center;"><%= message %></p>
            <% } %>
            <form id="loginForm"  method="post" action="/admin/login">
                <div class="input-group">
                    <label for="username">Username</label>
                    <input type="text" id="username" name="email" required>
                    <div class="error-message" id="usernameError">Please enter a valid username</div>
                </div>
                <div class="input-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" required>
                    <div class="error-message" id="passwordError">Password must be at least 6 characters</div>
                </div>
                <div class="forgot-password">
                    <a href="#">Forgot Password?</a>
                </div>
                <button type="submit" class="login-btn">Login</button>
            </form>
        </div>
    </div>

</body>
</html>
