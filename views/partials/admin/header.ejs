<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dental Shop Dashboard</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.7.0/chart.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/flowbite/2.2.0/flowbite.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.js"></script>
    <script>
        function updateHeading(heading) {
            document.getElementById('pageHeading').textContent = heading;
        }
    </script>
</head>
<body class="bg-gray-100">
    <div class="flex h-screen">
        <!-- Sidebar -->
        <aside class="w-64 bg-gray-800 text-white fixed h-full">
            <!-- Logo Section -->
            <div class="p-4 bg-yellow-400 text-gray-800 font-bold">
                DENT CART
            </div>

            <!-- User Profile Section -->
            <div class="p-4 border-b border-gray-700">
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 bg-gray-700 rounded-full flex items-center justify-center text-white">
                        <%= adminName[0] %>
                    </div>
                    <div>
                        <div class="font-medium"><%= adminName %></div>
                        <div class="text-sm text-gray-400">Administrator</div>
                    </div>
                </div>
                <div class="mt-3 space-y-2">
                    <a href="#" class="block text-sm text-gray-300 hover:text-white">Profile</a>
                    <form action="admin/logout" method="get">
                        <button type="submit" id="logoutButton" class="block text-sm text-gray-300 hover:text-white">
                            Logout
                        </button>
                    </form>
                </div>
            </div>

            <!-- Navigation Menu -->
            <nav class="mt-4">
                <a href="/admin/dashboard" class="block p-4 hover:bg-gray-700" onclick="setActive(this)">Dashboard</a>
                <a href="/admin/products" class="block p-4 hover:bg-gray-700" onclick="setActive(this)">Products</a>
                <a href="/orders" class="block p-4 hover:bg-gray-700" onclick="setActive(this)">Orders</a>
                <a href="/admin/users" class="block p-4 hover:bg-gray-700" onclick="setActive(this)">Customers</a>
                <a href="/inventory" class="block p-4 hover:bg-gray-700" onclick="setActive(this)">Inventory</a>
                <a href="/coupons" class="block p-4 hover:bg-gray-700" onclick="setActive(this)">Coupons</a>
                <a href="/offers" class="block p-4 hover:bg-gray-700" onclick="setActive(this)">Offers</a>
                <a href="/admin/category" class="block p-4 hover:bg-gray-700" onclick="setActive(this)">Categories</a>
                <a href="/reports" class="block p-4 hover:bg-gray-700" onclick="setActive(this)">Reports</a>
                <a href="/settings" class="block p-4 hover:bg-gray-700" onclick="setActive(this)">Settings</a>
            </nav>
        </aside>

        <!-- Main Content Area -->
        <main class="flex-1 ml-64 p-4">
            <!-- Content goes here -->
        